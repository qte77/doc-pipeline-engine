{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doc-pipeline.dev/schemas/CanonicalDoc.schema.json",
  "title": "CanonicalDoc",
  "description": "Normalized L0/L1/L2 content tree — the single most load-bearing contract. Feeds RAG, analysis, and future doc-graph.",
  "$defs": {
    "Node": {
      "type": "object",
      "required": ["id", "level", "kind", "text"],
      "properties": {
        "id": { "type": "string", "description": "Stable node id (e.g. 's.1.2.3')" },
        "level": { "type": "integer", "minimum": 0, "maximum": 6, "description": "0=doc, 1=section, 2=subsection, 3+=deeper" },
        "kind": { "enum": ["doc", "section", "subsection", "paragraph", "list", "table", "figure", "caption", "code", "formula", "footnote"] },
        "title": { "type": "string" },
        "text": { "type": "string" },
        "source_refs": {
          "type": "array",
          "description": "Back-pointers to ExtractionBundle.content.layout entries",
          "items": {
            "type": "object",
            "required": ["layout_index", "page"],
            "properties": {
              "layout_index": { "type": "integer", "minimum": 0 },
              "page": { "type": "integer", "minimum": 1 }
            }
          }
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/Node" }
        }
      },
      "additionalProperties": false
    }
  },
  "type": "object",
  "required": ["version", "source_sha256", "built_at", "root", "tier_summary"],
  "properties": {
    "version": { "const": "0.1.0" },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "built_at": { "type": "string", "format": "date-time" },
    "input_format": {
      "type": "object",
      "description": "If RecognizeInputFormat matched, which format was used to guide normalization",
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "root": { "$ref": "#/$defs/Node" },
    "tier_summary": {
      "type": "object",
      "description": "OpenViking-style tiered view: L0 is a 100-token summary, L1 is a 2k-token summary, L2 is full content",
      "required": ["l0", "l1"],
      "properties": {
        "l0": { "type": "string", "description": "≤100 tokens — title + one-line gist" },
        "l1": { "type": "string", "description": "≤2000 tokens — section-level summary" }
      }
    }
  },
  "additionalProperties": false
}
