{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OutputFormat",
  "description": "Meta-schema for domain pack output format definitions. Reserved stub — wired in v0.3.",
  "type": "object",
  "required": ["id", "version", "tier"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
    },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "tier": { "enum": ["quick", "comprehensive", "both"] }
  },
  "additionalProperties": false
}
