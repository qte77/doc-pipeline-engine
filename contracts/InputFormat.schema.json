{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "InputFormat",
  "description": "Meta-schema for domain pack input format definitions. Reserved stub — wired in v0.3.",
  "type": "object",
  "required": ["id", "version", "file_types"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+/[a-z0-9-]+$"
    },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "file_types": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
