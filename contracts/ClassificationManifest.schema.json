{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClassificationManifest",
  "description": "Optional Classify/Sort stage output. Reserved stub — wired in v0.2.",
  "type": "object",
  "required": ["version", "items"],
  "properties": {
    "version": { "const": "0.1.0" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "domain", "confidence"],
        "properties": {
          "path": { "type": "string" },
          "domain": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
