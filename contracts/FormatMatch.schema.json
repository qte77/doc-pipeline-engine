{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FormatMatch",
  "description": "RecognizeInputFormat stage output. Reserved stub — wired in v0.2.",
  "type": "object",
  "required": ["version", "matches"],
  "properties": {
    "version": { "const": "0.1.0" },
    "matches": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["format_id", "confidence"],
        "properties": {
          "format_id": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    }
  },
  "additionalProperties": false
}
